global:
  scrape_interval: 15s

scrape_configs:

  - job_name: node
    static_configs:
      - targets:
{% for host in groups['all'] %}
        - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endfor %}

  - job_name: cadvisor
    static_configs:
      - targets:
{% for host in groups['all'] %}
        - "{{ hostvars[host]['ansible_host'] }}:8080"
{% endfor %}