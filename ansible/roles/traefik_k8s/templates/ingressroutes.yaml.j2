# --- Traefik dashboard ---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: traefik-dashboard
  namespace: traefik
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`traefik.{{ domain }}`)
      kind: Rule
      services:
        - name: api@internal
          kind: TraefikService
  tls:
    certResolver: letsencrypt
---
# --- Grafana (K8s) ---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: grafana
  namespace: monitoring
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`grafana.{{ domain }}`)
      kind: Rule
      services:
        - name: grafana
          port: 3000
  tls:
    certResolver: letsencrypt
---
# --- Immich (Docker transitoire → IP host) ---
apiVersion: v1
kind: Service
metadata:
  name: immich-docker
  namespace: traefik
spec:
  ports:
    - port: 2283
---
apiVersion: v1
kind: Endpoints
metadata:
  name: immich-docker
  namespace: traefik
subsets:
  - addresses:
      - ip: 192.168.0.18
    ports:
      - port: 2283
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: immich
  namespace: traefik
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`immich.{{ domain }}`)
      kind: Rule
      services:
        - name: immich-docker
          port: 2283
  tls:
    certResolver: letsencrypt
---
